{
  "name": "asi-cartel-game",
  "version": "0.2.0",
  "description": "ASI Cartel - 6th Generation Warfare Strategy Game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:harness": "tsc -p tsconfig.harness.json && node scripts/write-harness-package.cjs",
    "playtest:harness": "npm run build:harness && node dist-harness/harness/server.js",
    "playtest:webhook-bridge": "npm run build:harness && node dist-harness/harness/webhookBridge.js",
    "playtest:codex-bridge": "npm run build:harness && node scripts/start-codex-bridge.cjs",
    "playtest:codex-bridge:probe": "node scripts/probe-codex-bridge.cjs",
    "tournament:harness": "npm run build:harness && node dist-harness/harness/tournament.js",
    "playtest:feedback-loop": "node scripts/run-codex-feedback-loop.cjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/three": "^0.160.0",
    "three": "^0.160.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
