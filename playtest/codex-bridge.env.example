# Copy this file to playtest/codex-bridge.env and fill in your local bridge values.
#
# Supported modes:
# - policy: local deterministic fallback only
# - roleplay: local no-auth faction personas behind the three webhook ports
# - openai: proxy local /decide bridge calls to an OpenAI-compatible upstream

THEYSING_BRIDGE_MODE=roleplay
THEYSING_BRIDGE_HOST=127.0.0.1
THEYSING_BRIDGE_TIMEOUT_MS=120000

# Point this at your local authenticated Codex/OpenAI-compatible bridge.
# Must be rooted at /v1.
# Use THEYSING_BRIDGE_OPENAI_API_STYLE=responses when your upstream only exposes
# /v1/responses. With the default auto mode, official OpenAI gpt-5-codex / *-pro
# models switch to Responses automatically, while local bridges stay on chat.
THEYSING_BRIDGE_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
THEYSING_BRIDGE_OPENAI_MODEL=gpt-5.2-codex
THEYSING_BRIDGE_OPENAI_API_STYLE=auto
THEYSING_BRIDGE_OPENAI_MAX_TOKENS=4000
THEYSING_BRIDGE_OPENAI_TEMPERATURE=0.2

# Optional bearer auth for local bridge.
# Leave blank if your local bridge does not use API keys.
THEYSING_BRIDGE_OPENAI_API_KEY=

# Optional extra headers as JSON.
# Useful if your local bridge expects cookies or a static custom header.
# Example:
# THEYSING_BRIDGE_OPENAI_HEADERS_JSON={"cookie":"session=...","x-csrf-token":"..."}
THEYSING_BRIDGE_OPENAI_HEADERS_JSON=

# Optional system prompt override for the bridge's upstream call.
# THEYSING_BRIDGE_SYSTEM_PROMPT=You are playing They Sing. Return JSON only.
